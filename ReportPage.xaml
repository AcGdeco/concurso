<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Concurso.ReportPage"
             Title="Relatório de Concursos">

    <Grid RowDefinitions="Auto,*">

        <!-- Header bar -->
        <Border Grid.Row="0" BackgroundColor="#2c3e50" Padding="10,6">
            <HorizontalStackLayout Spacing="10">
                <Button Text="← Voltar"
                        BackgroundColor="#2980b9"
                        TextColor="White"
                        CornerRadius="6"
                        Padding="12,6"
                        FontSize="13"
                        Clicked="OnVoltarClicked" />
                <Label x:Name="LblNovidadesBadge"
                       Text=""
                       TextColor="White"
                       BackgroundColor="#27ae60"
                       Padding="8,4"
                       VerticalOptions="Center"
                       FontSize="12"
                       FontAttributes="Bold" />
                <Label Text="📊 Relatório de Concursos Públicos"
                       TextColor="#ecf0f1"
                       VerticalOptions="Center"
                       FontSize="14"
                       FontAttributes="Bold" />
            </HorizontalStackLayout>
        </Border>

        <!-- Report WebView -->
        <WebView Grid.Row="1" x:Name="ReportWebView" />

    </Grid>
</ContentPage>
